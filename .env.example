VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
# Callback URL must match an Allowed callback URL on the Cognito app client.
# Optional: comma-separated OAuth scopes (must match Allowed OAuth scopes on the app client).
# Default: openid,email — enough for email, but Google often omits "name" until you add profile:
# VITE_COGNITO_OAUTH_SCOPES=openid,email,profile
# (Add "profile" to the Cognito app client + Google IdP attribute mapping for given_name/family_name/name if needed.)
VITE_COGNITO_REDIRECT_SIGN_IN=http://localhost:5173/home
VITE_COGNITO_REDIRECT_SIGN_OUT=http://localhost:5173/login
VITE_AUTH_DEBUG=false
# Feria REST API (ingest, voice-jobs, movements) — copy from CDK output ApiUrl
VITE_FERIA_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod/
