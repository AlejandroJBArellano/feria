# Copy to .env — same Cognito IDs as feria-infra/.env: COGNITO_USER_POOL_ID / CLIENT_ID / DOMAIN
# (here with VITE_ prefix). API Gateway authorizer must use this same pool after deploy.
VITE_COGNITO_REGION=mx-central-1
VITE_COGNITO_USER_POOL_ID=mx-central-1_XXXXXXXXX
VITE_COGNITO_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_COGNITO_DOMAIN=xxxxx.auth.mx-central-1.amazoncognito.com
VITE_COGNITO_REDIRECT_SIGN_IN=http://localhost:5173/home
VITE_COGNITO_REDIRECT_SIGN_OUT=http://localhost:5173/login
VITE_AUTH_DEBUG=false
# Must match "Allowed OAuth scopes" on the Cognito app client (e.g. openid,email or openid,email,profile)
VITE_COGNITO_OAUTH_SCOPES=openid,email

# Same deploy as the REST API — CloudFormation output ApiUrl (feria-rest-api, not UsersApiUrl)
VITE_FERIA_API_URL=https://xxxxxxxxxx.execute-api.mx-central-1.amazonaws.com/prod/

# Do NOT put AWS secrets or Bedrock keys here — Vite exposes VITE_* to the browser; Bedrock runs in Lambda.
